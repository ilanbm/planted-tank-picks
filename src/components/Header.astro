---
import { siteConfig } from "../config/site-config";

const pathname = Astro.url.pathname;
const navItems = [
  { href: "/calculator", label: "Calculator" },
  { href: "/filters/", label: "Filters" },
  { href: "/heaters/", label: "Heaters" },
  { href: "/lights/", label: "Lights" },
  { href: "/substrate/", label: "Substrate" },
  { href: "/guides/", label: "Guides" },
];

function isActive(href: string) {
  if (href === "/") return pathname === "/";
  return pathname.startsWith(href);
}
---
<header class="relative z-10">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-6 md:py-8">
    <a href="/" class="group flex items-center gap-3" aria-label={siteConfig.siteName}>
      <!-- Botanical mark -->
      <svg
        viewBox="0 0 40 40"
        class="h-8 w-8 text-moss-600 transition-transform duration-300 group-hover:rotate-[-6deg]"
        fill="none"
        stroke="currentColor"
        stroke-width="1.4"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M20 34 L20 14" />
        <path d="M20 14 C14 10 10 12 8 18 C12 22 16 22 20 18" fill="currentColor" fill-opacity="0.12" />
        <path d="M20 14 C26 10 30 12 32 18 C28 22 24 22 20 18" fill="currentColor" fill-opacity="0.08" />
        <path d="M20 22 C15 19 12 20 10 25 C14 28 17 28 20 25" fill="currentColor" fill-opacity="0.16" />
        <path d="M20 22 C25 19 28 20 30 25 C26 28 23 28 20 25" fill="currentColor" fill-opacity="0.12" />
        <path d="M14 34 L26 34" />
      </svg>
      <span class="flex flex-col leading-none">
        <span class="font-display text-xl font-medium tracking-tight text-ink-900">
          Planted Tank Gear
        </span>
        <span class="eyebrow mt-1 text-[0.62rem]">Straight-answer picks</span>
      </span>
    </a>

    <nav class="hidden items-center gap-1 md:flex" aria-label="Primary">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            "rounded-full px-3 py-1.5 text-[0.9rem] text-ink-700 transition-colors hover:text-moss-700",
            isActive(item.href) && "bg-moss-100 text-moss-700",
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <a
      href="/calculator"
      class="btn btn-primary hidden text-[0.85rem] md:inline-flex"
      style="padding: 0.55rem 1.15rem;"
    >
      Get my setup
      <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M5 12h14M13 5l7 7-7 7" />
      </svg>
    </a>

    <!-- Mobile nav toggle -->
    <details class="relative md:hidden">
      <summary class="list-none cursor-pointer rounded-full border border-ink-300 px-3 py-1.5 text-sm text-ink-900">
        Menu
      </summary>
      <div class="surface-elevated absolute right-0 top-[calc(100%+0.5rem)] w-52 p-2">
        {navItems.map((item) => (
          <a
            href={item.href}
            class="block rounded-md px-3 py-2 text-sm text-ink-900 hover:bg-cream-100"
          >
            {item.label}
          </a>
        ))}
      </div>
    </details>
  </div>
  <div class="mx-auto max-w-6xl px-6">
    <div class="rule-hair"></div>
  </div>
</header>

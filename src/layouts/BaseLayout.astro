---
import "../styles/global.css";
import Seo from "../components/Seo.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

type Props = {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  articleJsonLd?: Record<string, unknown>;
  faqJsonLd?: Record<string, unknown>;
  breadcrumbJsonLd?: Record<string, unknown>;
  /** "reading" = narrow max-w-3xl for articles; "wide" = full-bleed for homepage etc. */
  width?: "reading" | "wide";
};

const { width = "reading", ...seoProps } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;0,9..144,800;1,9..144,400&family=Inter:wght@400;500;600;700&display=swap"
    />
    <Seo {...seoProps} />
  </head>
  <body class="min-h-screen bg-cream-50 text-ink-900">
    <Header />
    {width === "wide" ? (
      <main>
        <slot />
      </main>
    ) : (
      <main class="mx-auto max-w-3xl px-6 py-10 md:py-14">
        <slot />
      </main>
    )}
    <Footer />
  </body>
</html>

---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render, type CollectionEntry } from "astro:content";
import { siteConfig } from "../../config/site-config";

export async function getStaticPaths() {
  const categories = await getCollection("categories");
  return categories.map((c: CollectionEntry<"categories">) => ({
    params: { category: c.data.slug },
    props: { category: c },
  }));
}

type Props = { category: CollectionEntry<"categories"> };
const { category } = Astro.props;
const { Content } = await render(category);

const decisions = await getCollection("decisions", (d) =>
  d.data.category === category.data.slug,
);

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `https://${siteConfig.domain}/` },
    { "@type": "ListItem", position: 2, name: category.data.title, item: `https://${siteConfig.domain}/${category.data.slug}/` },
  ],
};
---
<BaseLayout
  title={category.data.title}
  description={category.data.description}
  breadcrumbJsonLd={breadcrumbJsonLd}
>
  <nav aria-label="Breadcrumb" class="mb-8 text-[0.82rem] text-ink-500">
    <ol class="flex flex-wrap items-center gap-2">
      <li><a href="/" class="link-editorial">Home</a></li>
      <li aria-hidden="true" class="text-ink-300">/</li>
      <li class="capitalize text-ink-500">{category.data.slug}</li>
    </ol>
  </nav>

  <header>
    <div class="flex items-center gap-3">
      <span class="inline-flex h-1.5 w-6 rounded-full bg-moss-500"></span>
      <span class="eyebrow">Category guide</span>
    </div>
    <h1 class="mt-5 text-[2.5rem] leading-[1.05] md:text-[3.25rem]">
      {category.data.title}
    </h1>
    <p class="mt-5 text-lg leading-relaxed text-ink-700">
      {category.data.intro}
    </p>
  </header>

  <article class="prose prose-lg mt-10 max-w-none text-ink-900
    prose-headings:font-display prose-headings:tracking-tight
    prose-h2:text-[1.75rem] prose-h2:mt-12 prose-h2:mb-4
    prose-h3:text-[1.25rem] prose-h3:mt-8 prose-h3:mb-3
    prose-p:text-ink-700 prose-p:leading-relaxed
    prose-a:text-moss-700 prose-a:no-underline hover:prose-a:text-moss-600
    prose-strong:text-ink-900 prose-strong:font-semibold
    prose-ul:text-ink-700 prose-li:my-1
    prose-ol:text-ink-700"
  >
    <Content />
  </article>

  <section class="mt-14">
    <div class="eyebrow">Decision guides</div>
    <h2 class="mt-3 text-[1.75rem] leading-tight">Pick for your situation</h2>

    {decisions.length === 0 ? (
      <p class="mt-6 text-ink-500">Decision guides publishing soon.</p>
    ) : (
      <div class="mt-6 grid gap-4 md:grid-cols-2">
        {decisions.map((d) => (
          <a
            href={`/${d.data.category}/${d.data.slug}/`}
            class="surface surface-hover group flex items-center justify-between p-5"
          >
            <div>
              <div class="eyebrow text-[0.65rem] capitalize">{d.data.category}</div>
              <div class="mt-1 font-display text-[1.1rem] leading-snug text-ink-900" style="font-variation-settings: 'opsz' 24;">
                {d.data.h1}
              </div>
            </div>
            <svg
              class="h-4 w-4 flex-shrink-0 text-ink-500 transition-transform group-hover:translate-x-1 group-hover:text-moss-600"
              viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M5 12h14M13 5l7 7-7 7" />
            </svg>
          </a>
        ))}
      </div>
    )}
  </section>
</BaseLayout>

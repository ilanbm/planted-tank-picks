---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout
  title="Planted Tank Setup Calculator"
  description="Enter your tank size, planting level, livestock, and experience. Get a full equipment list recommended for your exact setup."
>
  <h1 class="mb-2 text-3xl font-bold text-emerald-900">
    Planted Tank Setup Calculator
  </h1>
  <p class="mb-6 text-gray-700">
    Answer four questions. We'll recommend a filter, heater, light, substrate,
    test kit, and (if applicable) CO₂ setup for your tank.
  </p>

  <form id="calc-form" class="space-y-4 rounded border border-emerald-200 p-4">
    <label class="block">
      <span class="mb-1 block font-medium">Tank size (gallons)</span>
      <select name="tankSizeGal" class="w-full rounded border-gray-300">
        <option value="5">5 gallons</option>
        <option value="10">10 gallons</option>
        <option value="20" selected>20 gallons</option>
        <option value="29">29 gallons</option>
        <option value="40">40 gallons</option>
        <option value="55">55 gallons</option>
        <option value="75">75 gallons</option>
        <option value="125">125+ gallons</option>
      </select>
    </label>

    <label class="block">
      <span class="mb-1 block font-medium">Planting level</span>
      <select name="planting" class="w-full rounded border-gray-300">
        <option value="low">Low-tech (no CO₂, slow growers)</option>
        <option value="medium" selected>Medium-tech (liquid carbon, mixed plants)</option>
        <option value="high">High-tech (CO₂ injected, demanding plants)</option>
      </select>
    </label>

    <label class="block">
      <span class="mb-1 block font-medium">Livestock</span>
      <select name="livestock" class="w-full rounded border-gray-300">
        <option value="community" selected>Community tropical</option>
        <option value="shrimp">Shrimp</option>
        <option value="betta">Betta</option>
        <option value="cichlid">Cichlid</option>
        <option value="species-only">Species-only</option>
      </select>
    </label>

    <label class="block">
      <span class="mb-1 block font-medium">Experience</span>
      <select name="experience" class="w-full rounded border-gray-300">
        <option value="first">First tank</option>
        <option value="some" selected>Some experience</option>
        <option value="experienced">Experienced</option>
      </select>
    </label>

    <button
      type="submit"
      class="rounded bg-emerald-700 px-5 py-2 text-white hover:bg-emerald-800"
    >
      Get my setup
    </button>
  </form>

  <section id="results" class="mt-8 hidden">
    <h2 class="mb-3 text-2xl font-semibold text-emerald-900">Your recommended setup</h2>
    <div id="results-body"></div>
    <p class="mt-4 text-xs text-gray-500">
      As an Amazon Associate we earn from qualifying purchases.
    </p>
  </section>

  <script>
    import { recommend } from "../data/calculator-rules";
    import { amazonUrl, amazonSearchUrl } from "../config/site-config";
    import type { Product } from "../data/products";

    const form = document.getElementById("calc-form") as HTMLFormElement | null;
    const results = document.getElementById("results") as HTMLElement | null;
    const body = document.getElementById("results-body") as HTMLElement | null;

    form?.addEventListener("submit", (e) => {
      e.preventDefault();
      if (!results || !body) return;
      const data = new FormData(form);
      const input = {
        tankSizeGal: Number(data.get("tankSizeGal")),
        planting: data.get("planting") as "low" | "medium" | "high",
        livestock: data.get("livestock") as
          | "community" | "shrimp" | "betta" | "cichlid" | "species-only",
        experience: data.get("experience") as "first" | "some" | "experienced",
      };
      const r = recommend(input);
      const rows: string[] = [];
      const pushRow = (label: string, p: Product | null) => {
        if (!p) return;
        const href = p.asin.startsWith("SEARCH:")
          ? amazonSearchUrl(p.asin.slice("SEARCH:".length))
          : amazonUrl(p.asin);
        rows.push(
          '<div class="mb-3 rounded border border-emerald-100 p-3">' +
            '<div class="text-sm uppercase tracking-wide text-emerald-700">' + label + '</div>' +
            '<div class="font-semibold">' + p.name + '</div>' +
            '<div class="text-sm text-gray-700">' + p.shortPitch + '</div>' +
            '<a href="' + href + '" target="_blank" rel="sponsored nofollow noopener" ' +
              'class="mt-1 inline-block text-emerald-800 underline">See on Amazon &rarr;</a>' +
          '</div>'
        );
      };
      pushRow("Filter", r.filter);
      pushRow("Heater", r.heater);
      pushRow("Light", r.light);
      pushRow("Substrate", r.substrate);
      pushRow("CO₂", r.co2);
      pushRow("Testing", r.testing);
      if (r.notes.length) {
        rows.push(
          '<div class="mt-4 rounded bg-amber-50 p-3 text-sm text-amber-900">' +
            '<strong>Notes:</strong>' +
            '<ul class="list-disc pl-5">' +
              r.notes.map((n) => '<li>' + n + '</li>').join('') +
            '</ul>' +
          '</div>'
        );
      }
      body.innerHTML = rows.join("");
      results.classList.remove("hidden");
      results.scrollIntoView({ behavior: "smooth" });
    });
  </script>
</BaseLayout>

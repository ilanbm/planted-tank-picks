---
import BaseLayout from "../layouts/BaseLayout.astro";

const experienceOptions = [
  { value: "first",        label: "First tank",      desc: "Starting out — we'll steer you safe" },
  { value: "some",         label: "Some experience", desc: "A few tanks under the belt" },
  { value: "experienced",  label: "Experienced",     desc: "Years in the hobby" },
];

const tankSizes = [
  { value: "unsure", label: "?",  detail: "not sure" },
  { value: 5,        label: "5",   detail: "nano" },
  { value: 10,       label: "10",  detail: "nano" },
  { value: 20,       label: "20",  detail: "sweet spot" },
  { value: 29,       label: "29",  detail: "midsize" },
  { value: 40,       label: "40",  detail: "midsize" },
  { value: 55,       label: "55",  detail: "large" },
  { value: 75,       label: "75",  detail: "large" },
  { value: 125,      label: "125+", detail: "big" },
];

const plantingOptions = [
  { value: "low",    label: "Low-tech",    desc: "No CO₂, slow growers" },
  { value: "medium", label: "Medium-tech", desc: "Liquid carbon, mixed plants" },
  { value: "high",   label: "High-tech",   desc: "CO₂ injected, demanding" },
  { value: "unsure", label: "Not sure yet", desc: "We'll pick a safe default" },
];

const livestockOptions = [
  { value: "community",    label: "Community",    desc: "Tetras, rasboras, corys" },
  { value: "shrimp",       label: "Shrimp",       desc: "Neocaridina, Caridina" },
  { value: "betta",        label: "Betta",        desc: "Solo or with peaceful mates" },
  { value: "cichlid",      label: "Cichlid",      desc: "Apistos, rams, angels" },
  { value: "species-only", label: "Species-only", desc: "Single species focus" },
  { value: "unsure",       label: "Not sure yet", desc: "We'll pick a safe default" },
];
---
<BaseLayout
  title="Planted Tank Setup Calculator"
  description="Four questions. A full equipment setup for your exact tank — filter, heater, light, substrate, CO₂, and test kit."
  width="wide"
>
  <!-- ==========================================================================
       HERO BAND
       ========================================================================== -->
  <section class="relative border-b border-cream-200 bg-cream-100 py-14 md:py-20">
    <div class="mx-auto max-w-4xl px-6">
      <div class="flex items-center gap-3">
        <span class="inline-flex h-1.5 w-6 rounded-full bg-moss-500"></span>
        <span class="eyebrow">The setup calculator</span>
      </div>
      <h1 class="mt-5 text-[2.5rem] leading-[1.05] md:text-[3.5rem]">
        Four questions.
        <span class="italic text-moss-600" style="font-variation-settings: 'opsz' 144;">One</span>
        setup.
      </h1>
      <p class="mt-5 max-w-2xl text-lg leading-relaxed text-ink-700">
        Tell us about your tank — or don't, if you're just exploring. We'll
        build a full gear list: filter, heater, light, substrate, CO₂ (if you
        need it), and test kit. Every pick comes with a one-line reason.
      </p>
    </div>
  </section>

  <!-- ==========================================================================
       FORM
       ========================================================================== -->
  <section class="mx-auto max-w-4xl px-6 py-14 md:py-20">
    <form id="calc-form" class="space-y-14">
      <!-- Q1 Experience (now first — anchors downstream defaults) -->
      <fieldset>
        <div class="flex items-baseline gap-3">
          <span class="font-display text-2xl text-moss-600" style="font-variation-settings: 'opsz' 24;">01</span>
          <legend class="text-[1.3rem] font-display text-ink-900" style="font-variation-settings: 'opsz' 24;">
            Where are you in the hobby?
          </legend>
        </div>
        <p class="mt-2 ml-10 text-sm text-ink-500">This shapes everything else. Beginners get safer picks; experienced keepers get performance-first options.</p>

        <div class="mt-6 ml-10 grid gap-3 md:grid-cols-3">
          {experienceOptions.map((o) => (
            <label class="cursor-pointer">
              <input
                type="radio"
                name="experience"
                value={o.value}
                class="peer sr-only experience-input"
                checked={o.value === "some"}
              />
              <div class="rounded-xl border border-cream-200 bg-cream-50 p-5 transition-all hover:border-moss-500 peer-checked:border-moss-500 peer-checked:bg-moss-100 peer-checked:shadow-sm">
                <div class="font-display text-lg text-ink-900" style="font-variation-settings: 'opsz' 24;">
                  {o.label}
                </div>
                <div class="mt-1 text-sm text-ink-500">{o.desc}</div>
              </div>
            </label>
          ))}
        </div>

        <!-- Beginner nudge (shown when First tank is selected) -->
        <div id="beginner-note" class="mt-5 ml-10 hidden rounded-xl border border-moss-500 bg-moss-100/60 p-4">
          <div class="flex gap-3">
            <svg class="h-5 w-5 flex-shrink-0 text-moss-600 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="9" />
              <path d="M12 8v4M12 16h.01" />
            </svg>
            <div class="text-[0.92rem] leading-relaxed text-ink-900">
              <strong class="font-semibold">Welcome to the hobby.</strong>
              Whether you already own a tank or you're just planning,
              we've pre-selected a forgiving starter setup below: 20 gal,
              low-tech plants, community fish. Adjust anything you've
              already decided — leave the rest as-is and we'll pick safely.
            </div>
          </div>
        </div>
      </fieldset>

      <div class="rule-hair"></div>

      <!-- Q2 Tank Size -->
      <fieldset>
        <div class="flex items-baseline gap-3">
          <span class="font-display text-2xl text-moss-600" style="font-variation-settings: 'opsz' 24;">02</span>
          <legend
            id="q2-legend"
            data-default="How big is your tank?"
            data-planning="What size are you planning?"
            class="text-[1.3rem] font-display text-ink-900"
            style="font-variation-settings: 'opsz' 24;"
          >
            How big is your tank?
          </legend>
        </div>
        <p
          id="q2-help"
          data-default="In US gallons. Not sure yet? Pick the question mark."
          data-planning="In US gallons. A 20 is the first-tank sweet spot — pick what you're planning or tap the ? if unsure."
          class="mt-2 ml-10 text-sm text-ink-500"
        >In US gallons. Not sure yet? Pick the question mark.</p>

        <div class="mt-6 ml-10 grid grid-cols-3 gap-2 md:grid-cols-9">
          {tankSizes.map((t) => (
            <label class="cursor-pointer">
              <input
                type="radio"
                name="tankSizeGal"
                value={t.value}
                class="peer sr-only tank-size-input"
                data-default={t.value === 20 ? "true" : "false"}
                checked={t.value === 20}
              />
              <div class="flex flex-col items-center justify-center rounded-xl border border-cream-200 bg-cream-50 px-2 py-4 transition-all hover:border-moss-500 peer-checked:border-moss-500 peer-checked:bg-moss-100 peer-checked:shadow-sm peer-focus-visible:ring-2 peer-focus-visible:ring-moss-500 peer-focus-visible:ring-offset-2">
                <div class="font-display text-xl text-ink-900" style="font-variation-settings: 'opsz' 24;">
                  {t.label}
                </div>
                <div class="mt-1 text-[0.62rem] uppercase tracking-wider text-ink-500">
                  {t.detail}
                </div>
              </div>
            </label>
          ))}
        </div>
      </fieldset>

      <div class="rule-hair"></div>

      <!-- Q3 Planting -->
      <fieldset>
        <div class="flex items-baseline gap-3">
          <span class="font-display text-2xl text-moss-600" style="font-variation-settings: 'opsz' 24;">03</span>
          <legend
            id="q3-legend"
            data-default="How planted is it?"
            data-planning="How planted do you want it?"
            class="text-[1.3rem] font-display text-ink-900"
            style="font-variation-settings: 'opsz' 24;"
          >
            How planted is it?
          </legend>
        </div>
        <p class="mt-2 ml-10 text-sm text-ink-500">The more plants, the more light and (often) CO₂ you'll want.</p>

        <div class="mt-6 ml-10 grid gap-3 md:grid-cols-4">
          {plantingOptions.map((o) => (
            <label class="cursor-pointer">
              <input
                type="radio"
                name="planting"
                value={o.value}
                class="peer sr-only planting-input"
                data-default={o.value === "medium" ? "true" : "false"}
                checked={o.value === "medium"}
              />
              <div class="h-full rounded-xl border border-cream-200 bg-cream-50 p-5 transition-all hover:border-moss-500 peer-checked:border-moss-500 peer-checked:bg-moss-100 peer-checked:shadow-sm">
                <div class="font-display text-lg text-ink-900" style="font-variation-settings: 'opsz' 24;">
                  {o.label}
                </div>
                <div class="mt-1 text-sm text-ink-500">{o.desc}</div>
              </div>
            </label>
          ))}
        </div>
      </fieldset>

      <div class="rule-hair"></div>

      <!-- Q4 Livestock -->
      <fieldset>
        <div class="flex items-baseline gap-3">
          <span class="font-display text-2xl text-moss-600" style="font-variation-settings: 'opsz' 24;">04</span>
          <legend
            id="q4-legend"
            data-default="What lives in there?"
            data-planning="What do you want to keep?"
            class="text-[1.3rem] font-display text-ink-900"
            style="font-variation-settings: 'opsz' 24;"
          >
            What lives in there?
          </legend>
        </div>
        <p class="mt-2 ml-10 text-sm text-ink-500">Shrimp need intake protection. Bettas want calm water. Cichlids push bigger filters.</p>

        <div class="mt-6 ml-10 grid gap-3 md:grid-cols-3 lg:grid-cols-6">
          {livestockOptions.map((o) => (
            <label class="cursor-pointer">
              <input
                type="radio"
                name="livestock"
                value={o.value}
                class="peer sr-only livestock-input"
                data-default={o.value === "community" ? "true" : "false"}
                checked={o.value === "community"}
              />
              <div class="h-full rounded-xl border border-cream-200 bg-cream-50 p-4 transition-all hover:border-moss-500 peer-checked:border-moss-500 peer-checked:bg-moss-100 peer-checked:shadow-sm">
                <div class="font-display text-[1.05rem] text-ink-900" style="font-variation-settings: 'opsz' 24;">
                  {o.label}
                </div>
                <div class="mt-1 text-[0.8rem] leading-snug text-ink-500">{o.desc}</div>
              </div>
            </label>
          ))}
        </div>
      </fieldset>

      <div class="pt-4">
        <button type="submit" class="btn btn-primary text-[0.95rem]" style="padding: 0.95rem 1.75rem;">
          Build my setup
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M13 5l7 7-7 7" />
          </svg>
        </button>
      </div>
    </form>
  </section>

  <!-- ==========================================================================
       RESULTS
       ========================================================================== -->
  <section id="results" class="hidden border-t border-cream-200 bg-cream-100 py-14 md:py-20">
    <div class="mx-auto max-w-4xl px-6">
      <div class="flex items-baseline justify-between gap-4">
        <div>
          <div class="eyebrow">Your recommended setup</div>
          <h2 class="mt-2 text-[2rem] leading-tight md:text-[2.5rem]">
            Here's what we'd buy.
          </h2>
        </div>
        <p id="results-summary" class="hidden text-right text-sm text-ink-500 md:block"></p>
      </div>

      <div id="results-body" class="mt-10 grid gap-4"></div>

      <div id="results-notes" class="mt-8"></div>

      <p class="mt-10 text-center text-[0.75rem] text-ink-500">
        As an Amazon Associate we earn from qualifying purchases.
      </p>
    </div>
  </section>

  <script>
    import { recommend } from "../data/calculator-rules";
    import type { CalculatorInput } from "../data/calculator-rules";
    import { amazonUrl, amazonSearchUrl } from "../config/site-config";
    import type { Product } from "../data/products";

    const form = document.getElementById("calc-form") as HTMLFormElement | null;
    const results = document.getElementById("results") as HTMLElement | null;
    const body = document.getElementById("results-body") as HTMLElement | null;
    const notes = document.getElementById("results-notes") as HTMLElement | null;
    const summary = document.getElementById("results-summary") as HTMLElement | null;
    const beginnerNote = document.getElementById("beginner-note") as HTMLElement | null;

    // --- Beginner-mode UX: when "First tank" is selected, nudge defaults
    //     and swap question labels to planning/future tense.
    const experienceInputs = document.querySelectorAll<HTMLInputElement>(".experience-input");
    function setRadioByValue(name: string, value: string) {
      const el = document.querySelector<HTMLInputElement>(`input[name="${name}"][value="${value}"]`);
      if (el) el.checked = true;
    }
    function applyBeginnerDefaults() {
      setRadioByValue("tankSizeGal", "20");
      setRadioByValue("planting", "low");
      setRadioByValue("livestock", "community");
    }
    function setLabelMode(planning: boolean) {
      const keys = ["q2-legend", "q3-legend", "q4-legend", "q2-help"];
      keys.forEach((id) => {
        const el = document.getElementById(id);
        if (!el) return;
        const next = planning ? el.dataset.planning : el.dataset.default;
        if (next) el.textContent = next;
      });
    }
    experienceInputs.forEach((input) => {
      input.addEventListener("change", () => {
        if (!input.checked) return;
        if (input.value === "first") {
          applyBeginnerDefaults();
          beginnerNote?.classList.remove("hidden");
          setLabelMode(true);
        } else {
          beginnerNote?.classList.add("hidden");
          setLabelMode(false);
        }
      });
    });

    // --- Category icon map for result cards
    function categoryIcon(label: string): string {
      const icons: Record<string, string> = {
        Filter:    '<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6 4h12l-1 14a2 2 0 0 1-2 2H9a2 2 0 0 1-2-2L6 4Z"/><path d="M8 8h8M9 12h6M10 16h4"/></svg>',
        Heater:    '<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v13"/><circle cx="12" cy="18" r="3"/></svg>',
        Light:     '<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M2 12h2M20 12h2M5 5l1.5 1.5M17.5 17.5L19 19M19 5l-1.5 1.5M6.5 17.5L5 19"/></svg>',
        Substrate: '<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 17h18M3 17l3-4 3 3 4-5 4 4 4-3v5"/></svg>',
        "CO₂":     '<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="7" cy="17" r="2"/><circle cx="12" cy="12" r="1.5"/><circle cx="17" cy="7" r="2.5"/></svg>',
        Testing:   '<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3h6v5l4 10a2 2 0 0 1-2 3H7a2 2 0 0 1-2-3l4-10V3Z"/><path d="M9 11h6"/></svg>',
      };
      return icons[label] ?? "";
    }

    form?.addEventListener("submit", (e) => {
      e.preventDefault();
      if (!results || !body || !notes || !summary) return;
      const data = new FormData(form);
      const tankRaw = data.get("tankSizeGal") as string;
      const input: CalculatorInput = {
        tankSizeGal: tankRaw === "unsure" ? "unsure" : Number(tankRaw),
        planting: data.get("planting") as CalculatorInput["planting"],
        livestock: data.get("livestock") as CalculatorInput["livestock"],
        experience: data.get("experience") as CalculatorInput["experience"],
      };
      const r = recommend(input);

      summary.textContent = r.setupSummary;
      summary.classList.remove("hidden");

      const rows: string[] = [];
      const makeCard = (label: string, p: Product | null) => {
        if (!p) return;
        const href = p.asin.startsWith("SEARCH:")
          ? amazonSearchUrl(p.asin.slice("SEARCH:".length))
          : amazonUrl(p.asin);
        rows.push(`
          <article class="surface-elevated group flex flex-col gap-4 p-6 md:flex-row md:items-start">
            <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-xl bg-moss-100 text-moss-600">
              ${categoryIcon(label)}
            </div>
            <div class="flex-grow">
              <div class="eyebrow">${label}</div>
              <h3 class="mt-1 font-display text-[1.25rem] leading-tight text-ink-900" style="font-variation-settings: 'opsz' 24;">
                ${p.name}
              </h3>
              <p class="mt-2 text-[0.95rem] leading-relaxed text-ink-700">
                ${p.shortPitch}
              </p>
            </div>
            <a
              href="${href}"
              target="_blank"
              rel="sponsored nofollow noopener"
              class="btn btn-primary flex-shrink-0 text-[0.82rem]"
              style="padding: 0.55rem 1.1rem;"
            >
              See on Amazon
              <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
          </article>
        `);
      };
      makeCard("Filter", r.filter);
      makeCard("Heater", r.heater);
      makeCard("Light", r.light);
      makeCard("Substrate", r.substrate);
      makeCard("CO₂", r.co2);
      makeCard("Testing", r.testing);
      body.innerHTML = rows.join("");

      if (r.notes.length) {
        notes.innerHTML = `
          <div class="rounded-xl border border-cream-200 bg-cream-50 p-6">
            <div class="eyebrow">Notes</div>
            <ul class="mt-3 space-y-2 text-[0.92rem] leading-relaxed text-ink-700">
              ${r.notes.map((n) => `
                <li class="flex gap-3">
                  <span class="mt-2 inline-block h-1 w-1 flex-shrink-0 rounded-full bg-moss-500"></span>
                  <span>${n}</span>
                </li>
              `).join("")}
            </ul>
          </div>
        `;
      } else {
        notes.innerHTML = "";
      }

      results.classList.remove("hidden");
      setTimeout(() => {
        results.scrollIntoView({ behavior: "smooth", block: "start" });
      }, 60);
    });
  </script>
</BaseLayout>

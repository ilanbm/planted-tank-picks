---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../config/site-config";

const categories = [
  { slug: "filters", label: "Filters", tagline: "Flow, media, silence." },
  { slug: "heaters", label: "Heaters", tagline: "Reliability above all." },
  { slug: "lights", label: "Lights", tagline: "What your plants eat." },
  { slug: "substrate", label: "Substrate", tagline: "Active or inert." },
  { slug: "co2", label: "CO₂", tagline: "Dual-stage, no shortcuts." },
  { slug: "testing", label: "Testing", tagline: "Numbers over guesses." },
  { slug: "plants", label: "Plants", tagline: "Match to your setup." },
  { slug: "accessories", label: "Accessories", tagline: "Timers, shears, tools." },
];

const guides = [
  {
    href: "/guides/starting-a-planted-tank/",
    kicker: "Complete guide",
    title: "Starting a planted tank",
    description:
      "Tank, filter, heater, light, substrate. The order they matter, and the picks that won't bite you later.",
  },
  {
    href: "/guides/low-tech-planted-tank/",
    kicker: "For beginners",
    title: "The low-tech planted tank",
    description:
      "No CO₂. Modest light. The plants that actually thrive, and the ones to avoid.",
  },
  {
    href: "/guides/nano-shrimp-setup/",
    kicker: "Nano builds",
    title: "Nano shrimp tank setup",
    description:
      "How to build a 5–10 gallon shrimp tank that stays stable and keeps babies alive.",
  },
];
---
<BaseLayout
  title={siteConfig.siteName}
  description={siteConfig.description}
  width="wide"
>
  <!-- ==========================================================================
       HERO
       ========================================================================== -->
  <section class="grain relative overflow-hidden">
    <!-- Soft botanical backdrop -->
    <div class="pointer-events-none absolute inset-0 -z-10">
      <div
        class="absolute inset-x-0 top-0 h-[560px] opacity-90"
        style="background: radial-gradient(ellipse at 20% 10%, #e6efe9 0%, rgba(230,239,233,0) 55%), radial-gradient(ellipse at 85% 35%, #e8f0f0 0%, rgba(232,240,240,0) 50%), linear-gradient(180deg, var(--color-cream-50) 0%, var(--color-cream-50) 100%);"
      ></div>
    </div>

    <div class="mx-auto grid max-w-6xl grid-cols-1 gap-12 px-6 pb-20 pt-6 md:pb-28 md:pt-10 lg:grid-cols-[1.1fr_1fr] lg:items-center lg:gap-16">
      <div>
        <div class="flex items-center gap-3">
          <span class="inline-flex h-1.5 w-6 rounded-full bg-moss-500"></span>
          <span class="eyebrow">A field guide for planted tanks</span>
        </div>

        <h1 class="mt-6 text-[2.75rem] leading-[1.02] md:text-[4rem] lg:text-[4.5rem]">
          The right gear
          <br class="hidden md:inline" />
          for your
          <span class="italic text-moss-600" style="font-variation-settings: 'opsz' 144;">
            exact
          </span>
          setup.
        </h1>

        <p class="mt-7 max-w-xl text-lg leading-relaxed text-ink-700">
          Gear guides for planted freshwater aquariums. Tell us four things
          about your tank and we'll come back with a full setup: filter,
          heater, light, substrate, and CO₂ if you need it. Tuned to your
          tank size, plants, and livestock.
        </p>

        <div class="mt-9 flex flex-wrap items-center gap-4">
          <a href="/calculator" class="btn btn-primary">
            Run the calculator
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M13 5l7 7-7 7" />
            </svg>
          </a>
          <a href="/guides/starting-a-planted-tank/" class="link-editorial font-medium text-[0.95rem]">
            Or read the starter guide
          </a>
        </div>

        <!-- Trust strip -->
        <div class="mt-12 grid grid-cols-3 gap-6 border-t border-cream-200 pt-6 text-[0.82rem] text-ink-500 md:max-w-lg">
          <div>
            <div class="font-display text-2xl text-moss-600" style="font-variation-settings: 'opsz' 48;">4</div>
            <div class="mt-1">questions, one setup</div>
          </div>
          <div>
            <div class="font-display text-2xl text-moss-600" style="font-variation-settings: 'opsz' 48;">8</div>
            <div class="mt-1">gear categories</div>
          </div>
          <div>
            <div class="font-display text-2xl text-moss-600" style="font-variation-settings: 'opsz' 48;">3</div>
            <div class="mt-1">long-form guides</div>
          </div>
        </div>
      </div>

      <!-- Hero visual -->
      <div class="relative">
        <div class="relative aspect-[4/5] w-full max-w-[480px] mx-auto lg:ml-auto">
          <!-- Image slot with gradient fallback -->
          <div class="surface-elevated relative h-full w-full overflow-hidden rounded-[20px]">
            <picture>
              <!-- Fallback gradient for slow image loads -->
              <div
                class="absolute inset-0 bg-gradient-to-br from-[#2d5a42] via-[#3e7355] to-[#5a8a91]"
                aria-hidden="true"
              ></div>
              <img
                src="/images/hero-aquascape.webp"
                alt="A lush, expertly planted aquarium with moss, Anubias, and warm light filtering through water"
                loading="eager"
                fetchpriority="high"
                class="relative h-full w-full object-cover"
                onerror="this.style.display='none'"
              />
            </picture>
            <!-- Soft overlay for depth -->
            <div
              class="pointer-events-none absolute inset-0"
              style="background: linear-gradient(180deg, rgba(19,28,25,0) 55%, rgba(19,28,25,0.45) 100%);"
            ></div>
            <!-- Caption plate -->
            <div class="absolute bottom-4 left-4 right-4 rounded-xl bg-cream-50/95 p-4 backdrop-blur-sm">
              <div class="eyebrow text-[0.62rem]">The setup calculator picks</div>
              <p class="mt-1 font-display text-[1.05rem] leading-tight text-ink-900" style="font-variation-settings: 'opsz' 24;">
                Fluval 107 &middot; Eheim Jager 100W &middot; Week Aqua P600 Pro
              </p>
              <p class="mt-1 text-[0.72rem] text-ink-500">
                20-gal high-tech, community fish, intermediate
              </p>
            </div>
          </div>

          <!-- Decorative leaf accent -->
          <svg
            class="absolute -left-6 -top-8 h-28 w-28 text-moss-500 opacity-60"
            viewBox="0 0 120 120"
            fill="none"
            stroke="currentColor"
            stroke-width="1.2"
            aria-hidden="true"
          >
            <path d="M20 100 C 20 60, 40 30, 80 20 C 70 55, 55 80, 20 100 Z" fill="currentColor" fill-opacity="0.08" />
            <path d="M20 100 C 40 80, 55 60, 70 35" />
            <path d="M34 82 L 50 72" />
            <path d="M42 72 L 56 62" />
            <path d="M50 62 L 62 52" />
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- ==========================================================================
       APPROACH
       ========================================================================== -->
  <section class="mx-auto max-w-6xl px-6 py-20">
    <div class="grid items-start gap-10 md:grid-cols-[1fr_2fr]">
      <div>
        <div class="eyebrow">The approach</div>
        <h2 class="mt-3 text-[2.25rem] leading-[1.05] md:text-[2.75rem]">
          One pick, with reasons.
        </h2>
      </div>
      <p class="text-lg leading-relaxed text-ink-700 md:pt-3">
        Every decision page names a winner for a specific situation. Your
        tank size. Your plants. Your livestock. We say who the alternatives
        are for, too. When the situation changes, the pick changes.
      </p>
    </div>

    <div class="mt-12 grid grid-cols-1 gap-5 md:grid-cols-3">
      <article class="surface surface-hover p-7">
        <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-moss-100">
          <svg class="h-6 w-6 text-moss-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 6h16M4 12h16M4 18h10" />
          </svg>
        </div>
        <h3 class="mt-5 text-xl">Read the situation first</h3>
        <p class="mt-2 text-[0.95rem] leading-relaxed text-ink-700">
          Tank size, planting level, livestock, experience. The same "best
          filter" changes when any of these change.
        </p>
      </article>

      <article class="surface surface-hover p-7">
        <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-moss-100">
          <svg class="h-6 w-6 text-moss-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 2v20M5 9l7-7 7 7" />
          </svg>
        </div>
        <h3 class="mt-5 text-xl">Pick one, with reasons</h3>
        <p class="mt-2 text-[0.95rem] leading-relaxed text-ink-700">
          Every decision page names a winner and explains who the alternative
          is for. No padded "it depends."
        </p>
      </article>

      <article class="surface surface-hover p-7">
        <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-moss-100">
          <svg class="h-6 w-6 text-moss-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="9" />
            <path d="M8 12l3 3 5-6" />
          </svg>
        </div>
        <h3 class="mt-5 text-xl">Update when the hobby does</h3>
        <p class="mt-2 text-[0.95rem] leading-relaxed text-ink-700">
          Picks carry a last-updated date. When community consensus shifts or a
          product is discontinued, so does our pick.
        </p>
      </article>
    </div>
  </section>

  <!-- ==========================================================================
       CATEGORY GRID
       ========================================================================== -->
  <section class="bg-cream-100 py-20">
    <div class="mx-auto max-w-6xl px-6">
      <div class="flex items-end justify-between gap-4">
        <div>
          <div class="eyebrow">Browse by category</div>
          <h2 class="mt-3 text-[2.25rem] leading-[1.05] md:text-[2.75rem]">
            Every category, in depth.
          </h2>
        </div>
        <a href="/guides/" class="link-editorial hidden font-medium md:inline">
          See all guides &rarr;
        </a>
      </div>

      <div class="mt-10 grid grid-cols-2 gap-3 md:grid-cols-4">
        {categories.map((c) => (
          <a
            href={`/${c.slug}/`}
            class="surface surface-hover group flex flex-col justify-between p-5 md:p-6 md:min-h-[160px]"
          >
            <div class="flex items-start justify-between">
              <span class="font-display text-[1.35rem] leading-tight text-ink-900" style="font-variation-settings: 'opsz' 24;">
                {c.label}
              </span>
              <svg
                class="h-4 w-4 translate-x-0 text-ink-500 transition-transform group-hover:translate-x-1 group-hover:text-moss-600"
                viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M5 12h14M13 5l7 7-7 7" />
              </svg>
            </div>
            <p class="mt-6 text-[0.85rem] text-ink-500">{c.tagline}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ==========================================================================
       GUIDES
       ========================================================================== -->
  <section class="mx-auto max-w-6xl px-6 py-20">
    <div class="max-w-2xl">
      <div class="eyebrow">Start here</div>
      <h2 class="mt-3 text-[2.25rem] leading-[1.05] md:text-[2.75rem]">
        The long-form guides.
      </h2>
      <p class="mt-4 text-lg leading-relaxed text-ink-700">
        Three pillar pieces for when a single pick isn't the whole answer
        you're after.
      </p>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {guides.map((g, i) => (
        <a href={g.href} class="group flex flex-col">
          <div class="relative aspect-[4/3] overflow-hidden rounded-[14px] border border-cream-200">
            <div
              class="absolute inset-0"
              style={`background: linear-gradient(135deg, ${
                ["#2d5a42", "#3e7355", "#5a8a91"][i]
              } 0%, #1f4230 100%);`}
              aria-hidden="true"
            ></div>
            <!-- Botanical overlay -->
            <svg
              class="absolute inset-0 h-full w-full opacity-25 transition-transform duration-700 group-hover:scale-105"
              viewBox="0 0 400 300"
              preserveAspectRatio="xMidYMid slice"
              aria-hidden="true"
            >
              <defs>
                <pattern id={`leaves-${i}`} x="0" y="0" width="80" height="80" patternUnits="userSpaceOnUse">
                  <path d="M40 70 C 40 45, 55 30, 75 25 C 70 50, 60 65, 40 70 Z" fill="#fbf8f2" fill-opacity="0.4" />
                  <path d="M40 70 C 40 45, 25 30, 5 25 C 10 50, 20 65, 40 70 Z" fill="#fbf8f2" fill-opacity="0.3" />
                </pattern>
              </defs>
              <rect width="400" height="300" fill={`url(#leaves-${i})`} />
            </svg>
            <div class="absolute inset-0 flex items-end p-5">
              <div class="text-cream-50">
                <div class="eyebrow text-[0.62rem] text-cream-50/80">{g.kicker}</div>
                <div class="mt-1 font-display text-[1.35rem] leading-tight" style="font-variation-settings: 'opsz' 24;">
                  {g.title}
                </div>
              </div>
            </div>
          </div>
          <p class="mt-4 text-[0.95rem] leading-relaxed text-ink-700">
            {g.description}
          </p>
          <span class="mt-3 inline-flex items-center gap-1 text-[0.85rem] font-medium text-moss-600 group-hover:text-moss-700">
            Read the guide
            <svg class="h-3.5 w-3.5 transition-transform group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M13 5l7 7-7 7" />
            </svg>
          </span>
        </a>
      ))}
    </div>
  </section>

  <!-- ==========================================================================
       CTA BAND
       ========================================================================== -->
  <section class="mx-auto max-w-6xl px-6 pb-24">
    <div
      class="relative overflow-hidden rounded-[20px] px-8 py-16 md:px-16 md:py-20"
      style="background: linear-gradient(135deg, #1f4230 0%, #2d5a42 50%, #3e7355 100%);"
    >
      <div class="grain absolute inset-0 opacity-60"></div>
      <!-- Decorative stem -->
      <svg class="absolute -right-10 -top-10 h-72 w-72 text-cream-50 opacity-[0.06]" viewBox="0 0 200 200" fill="currentColor" aria-hidden="true">
        <path d="M100 180 L100 60 M100 60 C 70 50, 55 30, 60 10 C 90 20, 105 45, 100 60 M100 90 C 130 80, 150 60, 155 40 C 125 40, 105 70, 100 90 M100 130 C 70 115, 50 100, 60 75 C 90 85, 110 110, 100 130" stroke="currentColor" stroke-width="1.5" fill="none" />
      </svg>
      <div class="relative max-w-2xl">
        <div class="eyebrow text-cream-50/80">The fastest path</div>
        <h2 class="mt-3 text-[2.25rem] leading-[1.05] text-cream-50 md:text-[3rem]">
          Four questions. One setup.
          <span class="italic text-cream-50/90" style="font-variation-settings: 'opsz' 144;">
            Yours.
          </span>
        </h2>
        <p class="mt-5 max-w-xl text-[1.05rem] leading-relaxed text-cream-50/80">
          Tank size. Planting level. Livestock. Experience. We'll build the
          right gear list, with honest rationale for every pick.
        </p>
        <a
          href="/calculator"
          class="mt-8 inline-flex items-center gap-2 rounded-full bg-cream-50 px-6 py-3 font-medium text-ink-900 transition-transform hover:-translate-y-0.5"
        >
          Run the calculator
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M13 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
